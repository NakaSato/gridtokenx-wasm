# ==============================================================================
# GridTokenX Platform - Unified Environment Configuration
# ==============================================================================

# --- General ---
TZ=UTC
ENVIRONMENT=development
TEST_MODE=false

# --- Infrastructure: PostgreSQL ---
POSTGRES_DB=gridtokenx
POSTGRES_USER=gridtokenx_user
POSTGRES_PASSWORD=gridtokenx_password
# Native processes connect to localhost:5434 (mapped from Docker 5432)
DATABASE_URL=postgresql://gridtokenx_user:gridtokenx_password@localhost:5434/gridtokenx
IAM_DATABASE_URL=postgresql://gridtokenx_user:gridtokenx_password@localhost:5434/gridtokenx_iam
TRADING_DATABASE_URL=postgresql://gridtokenx_user:gridtokenx_password@localhost:5434/gridtokenx_trading
MAX_CONNECTIONS=100
MIN_CONNECTIONS=10
DATABASE_MAX_CONNECTIONS=100
DATABASE_MIN_CONNECTIONS=10

# --- Infrastructure: Redis ---
REDIS_PORT=6379
REDIS_URL=redis://127.0.0.1:6379
REDIS_POOL_SIZE=20

# --- Infrastructure: InfluxDB ---
INFLUXDB_PORT=8086
INFLUXDB_ORG=gridtokenx
INFLUXDB_BUCKET=energy_readings
INFLUXDB_USER=gridtokenx_user
INFLUXDB_PASSWORD=gridtokenx_password
INFLUXDB_TOKEN=your-influxdb-token
INFLUXDB_URL=http://localhost:8086

# --- Infrastructure: Kafka ---
KAFKA_ENABLED=true
KAFKA_PORT=9092
KAFKA_BOOTSTRAP_SERVERS=localhost:29092
KAFKA_TOPIC=meter-readings
KAFKA_CONSUMER_GROUP=gridtokenx-gateway

# --- Service: API Gateway ---
PORT=4000
APIGATEWAY_PORT=4000
SERVER_HOST=0.0.0.0
REQUEST_TIMEOUT=30
RUST_LOG=info
LOG_LEVEL=info
LOG_FORMAT=json
AUDIT_LOG_ENABLED=true

# --- Service: IAM & Trading (Internal URLs) ---
IAM_SERVICE_URL=http://127.0.0.1:8080
IAM_GRPC_URL=http://127.0.0.1:8090
TRADING_GRPC_URL=http://127.0.0.1:8092

# --- Service: Oracle Bridge & Simulator ---
SIMULATOR_URL=http://127.0.0.1:8082
SMARTMETER_PORT=8082
API_GATEWAY_URL=http://127.0.0.1:4000
API_KEY=engineering-department-api-key-2025

# --- Solana Blockchain ---
SOLANA_CLUSTER=localnet
SOLANA_RPC_URL=http://localhost:8899
SOLANA_WS_URL=ws://localhost:8900
SOLANA_RPC_PORT=8899
SOLANA_WS_PORT=8900

# --- Solana Program IDs ---
SOLANA_REGISTRY_PROGRAM_ID=FmvDiFUWPrwXsqo7z7XnVniKbZDcz32U5HSDVwPug89c
SOLANA_TRADING_PROGRAM_ID=69dGpKu9a8EZiZ7orgfTH6CoGj9DeQHHkHBF2exSr8na
SOLANA_ORACLE_PROGRAM_ID=JDUVXMkeGi4oxLp8njBaGScAFaVBBg7iGoiqcY1LxKop
SOLANA_GOVERNANCE_PROGRAM_ID=DamT9e1VqbA5nSyFZHExKwQu6qs4L5FW6dirWCK8YLd4
SOLANA_ENERGY_TOKEN_PROGRAM_ID=n52aKuZwUeZAocpWqRZAJR4xFhQqAvaRE7Xepy2JBGk

# --- Authority & Wallets ---
AUTHORITY_WALLET_PATH=./dev-wallet.json
ENERGY_TOKEN_MINT=FYoHgS599B9ZmCeyDpoTVYTR2K165py1HpyC1QkxqFzN
FEE_COLLECTOR_WALLET=BT9ESAZoNGnvPswpeHNLgt582GTQrAUv21ZLkk4H6Bad

# --- Security & Credentials ---
JWT_SECRET=dev-jwt-secret-key-minimum-32-characters-long-for-development-2025
JWT_EXPIRATION=86400
API_KEY_SECRET=test-api-key-secret-for-development-and-testing
GRIDTOKENX_API_KEYS=test-key-2025,engineering-department-api-key-2025
ENGINEERING_API_KEY=engineering-department-api-key-2025
ENCRYPTION_SECRET=dev-encryption-secret-key-32-chars-minimum-for-wallet-encryption

# --- Email (Mailpit) ---
SMTP_HOST=localhost
SMTP_PORT=1025
EMAIL_FROM_NAME=GridTokenX
EMAIL_FROM_ADDRESS=noreply@gridtokenx.com
EMAIL_VERIFICATION_ENABLED=true
EMAIL_VERIFICATION_REQUIRED=false
EMAIL_VERIFICATION_BASE_URL=http://localhost:3000

# --- Monitoring & Observability ---
ENABLE_METRICS=true
ENABLE_TRACING=true
OTEL_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4317
OTEL_TRACES_SAMPLER=always_on

# --- CORS ---
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4000
CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS

# --- Rate Limiting ---
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW=60

# --- Feature Flags ---
ENABLE_WEBSOCKET=true
ENABLE_BLOCKCHAIN_INTEGRATION=true
ENABLE_MARKET_DYNAMICS=true

# --- Tokenization Logic ---
TOKENIZATION_AUTO_MINT_ENABLED=true
TOKENIZATION_DECIMALS=9
TOKENIZATION_KWH_TO_TOKEN_RATIO=1.0

